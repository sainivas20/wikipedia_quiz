# WikiQuiz Environment Variables
# Copy this file to .env and fill in your values

# ── LLM API Key ──────────────────────────────────────────────────────
# Gemini (Google) — FREE tier, no credit card needed
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyABZjk1_jb92YFbAZZkC0-atRFuCNp9sbY

# Free-tier limits for gemini-1.5-flash:
#   15 requests/minute | 1,000,000 tokens/minute | 1,500 requests/day
# To upgrade to paid, change GEMINI_MODEL in llm_service.py to "gemini-1.5-pro"

# ── Database ─────────────────────────────────────────────────────────
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://wikiquizuser:yourpassword@localhost:5432/wikiquiz

# SQLite (auto-used if DATABASE_URL is not set — good for local dev)
# DATABASE_URL=sqlite:///./wikiquiz.db
